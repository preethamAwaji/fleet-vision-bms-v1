{
  "version": 2,
  "builds": [
    {
      "src": "frontend_1/Fleet_Intelligence_Platform/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend_1/Fleet_Intelligence_Platform/$1"
    }
  ],
  "buildCommand": "cd frontend_1/Fleet_Intelligence_Platform && npm install && npm run build",
  "outputDirectory": "frontend_1/Fleet_Intelligence_Platform/dist",
  "framework": "vite"
}
